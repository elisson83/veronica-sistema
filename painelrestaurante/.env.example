# PainelRestaurante — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

SECRET_KEY=troque_por_uma_chave_secreta_longa

# WhatsApp Business Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Porta do servidor
PORT=5006

# URL do PainelFrota (para QR code de conexão)
PAINELFROTA_URL=http://localhost:5004

# URL do AppMotoboy (para comprovante PDF)
MOTOBOY_API_URL=http://localhost:5003

# MercadoPago (para link de pagamento automático — opcional)
MERCADOPAGO_ACCESS_TOKEN=
